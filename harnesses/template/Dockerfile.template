# Template: Dockerfile for a new harness
#
# This is a starting point. You'll need to:
# 1. Replace <HARNESS_NAME> with your harness name (e.g. "cursor")
# 2. Replace <npm-package-name> with the npm package name
# 3. Adjust the base image if needed (this one is Chainguard Node.js)
#
# Place this file in the same directory as your harness script.
# The build context is the harness directory itself (where this file lives).

FROM cgr.dev/chainguard/node:latest-dev

# Install runtime dependencies.
# The -dev base image includes git and openssh-client — we remove them.
# No git, no SSH. By design.
USER root
RUN apk del --no-cache git openssh-client 2>/dev/null || true
RUN apk add --no-cache \
        curl \
        ca-certificates \
        tmux \
        ripgrep \
        bubblewrap \
        socat

# Install the agent.
# Defaults to latest; pin a version in config.json with {"<name>": {"version": "1.0.0"}}
# Option A: npm package
ARG VERSION=
RUN if [ -n "$VERSION" ]; then \
        npm install -g "<npm-package-name>@${VERSION}"; \
    else \
        npm install -g "<npm-package-name>"; \
    fi

# Option B: direct download from GitHub releases (uncomment and replace Option A)
# ARG VERSION=
# RUN if [ -n "$VERSION" ]; then \
#         curl -fsSL "https://github.com/org/repo/releases/download/${VERSION}/<file>-linux-${TARGETARCH}.tar.gz" \
#         | tar xz -C /usr/local/bin/; \
#     else \
#         curl -fsSL "https://github.com/org/repo/releases/latest/download/<file>-linux-${TARGETARCH}.tar.gz" \
#         | tar xz -C /usr/local/bin/; \
#     fi
# RUN chmod +x /usr/local/bin/<binary>

# Prepend extension binaries (host-mounted via /agent-config).
ENV PATH="/agent-config/bin:${PATH}"

# /home/agentuser: world-writable (1777) so any runtime UID can write here.
# /etc/passwd: world-writable so the entrypoint can add the runtime UID.
RUN mkdir -p /home/agentuser \
    && chmod 1777 /home/agentuser \
    && chmod a+w /etc/passwd

ENV HOME=/home/agentuser

# Copy the harness-specific entrypoint.
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]