#!/usr/bin/env bash
# agent-sandbox — Run AI coding harnesses inside Docker containers for security isolation
set -euo pipefail

# Resolve the installation directory (where this script lives)
# Follow symlinks so the script works when installed via npm/brew symlinks.
_resolve_script_path() {
    local src="${BASH_SOURCE[0]}"
    while [[ -L "$src" ]]; do
        local dir
        dir="$(cd "$(dirname "$src")" && pwd)"
        src="$(readlink "$src")"
        [[ "$src" != /* ]] && src="$dir/$src"
    done
    cd "$(dirname "$src")" && pwd
}
SCRIPT_DIR="$(_resolve_script_path)"
LIB_DIR="${SCRIPT_DIR}/../lib"

# Load common functions
# shellcheck source=lib/common.sh
source "${LIB_DIR}/common.sh"

# ─── Command: init ───────────────────────────────────────────────────────────

cmd_init() {
    local force=""
    if [[ "${1:-}" == "--force" ]]; then
        force="1"
    fi

    local config_dir
    config_dir="$(get_config_file_dir)"
    local config_file="${config_dir}/config.json"

    if [[ -f "${config_file}" ]] && [[ -z "${force}" ]]; then
        info "Config file already exists at ${config_file}"
        info "Use 'agent-sandbox init --force' to overwrite."
        exit 0
    fi

    mkdir -p "${config_dir}"

    # Discover all built-in harnesses and write their defaults to config.
    local harness_json="{}"
    local harness_dir harness_name
    for harness_dir in "${AGENT_SANDBOX_DIR}/harnesses"/*/; do
        harness_name="$(basename "${harness_dir}")"
        if [[ "${harness_name}" == "template" ]]; then
            continue
        fi

        local harness_script="${harness_dir}${harness_name}.sh"
        if [[ ! -f "${harness_script}" ]]; then
            continue
        fi

        # shellcheck source=/dev/null
        source "${harness_script}"

        local default_config_dir="${HARNESS_DEFAULT_CONFIG_DIR}"
        local default_data_dir="${HARNESS_DEFAULT_DATA_DIR}"
        local entry
        entry="$(jq -n \
            --arg config_dir "${default_config_dir}" \
            --arg data_dir "${default_data_dir}" \
            '{config_dir: $config_dir, data_dir: $data_dir}')"

        harness_json="$(echo "${harness_json}" | jq \
            --arg name "${harness_name}" \
            --argjson entry "${entry}" \
            '.harnesses[$name] = $entry')"
    done

    echo "${harness_json}" | jq . > "${config_file}"

    info "Created config file at ${config_file}"
    info ""
    info "Run 'agent-sandbox pi' to start the pi coding agent."
}

# ─── Command: list ───────────────────────────────────────────────────────────

cmd_list() {
    local config_file
    config_file="$(get_config_file)"

    if [[ ! -f "${config_file}" ]]; then
        die "Config file not found at ${config_file}. Run 'agent-sandbox init' first."
    fi

    info "Registered harnesses:"
    info ""

    # List built-in harnesses
    local harness_dir harness_name
    for harness_dir in "${AGENT_SANDBOX_DIR}/harnesses"/*/; do
        harness_name="$(basename "${harness_dir}")"
        if [[ "${harness_name}" == "template" ]]; then
            continue
        fi

        local harness_script="${harness_dir}${harness_name}.sh"
        if [[ ! -f "${harness_script}" ]]; then
            continue
        fi

        # shellcheck source=/dev/null
        source "${harness_script}"

        local config_dir
        config_dir="$(get_config_dir "${harness_name}")"

        echo "  ${HARNESS_NAME} (${harness_name})"
        echo "    image:      ${HARNESS_IMAGE}"
        echo "    config_dir: ${config_dir}"
        echo "    data_dir:   $(get_data_dir "${harness_name}")"
        echo "    mounts:     ${HARNESS_CONFIG_MOUNT_POINT}, ${HARNESS_DATA_MOUNT_POINT}"
    done

    # List user-registered harnesses from config.json
    local registered
    registered="$(jq -r '.harnesses | keys[]' "${config_file}" 2>/dev/null)" || true
    for harness_name in ${registered:-}; do
        # Skip built-in harnesses (already listed above)
        if [[ -f "${AGENT_SANDBOX_DIR}/harnesses/${harness_name}/${harness_name}.sh" ]]; then
            continue
        fi

        local script_path config_dir_harness data_dir_harness
        script_path="$(jq -r ".harnesses.\"${harness_name}\".script // \"\"" "${config_file}")"
        config_dir_harness="$(jq -r ".harnesses.\"${harness_name}\".config_dir // \"\"" "${config_file}")"
        data_dir_harness="$(jq -r ".harnesses.\"${harness_name}\".data_dir // \"\"" "${config_file}")"

        echo "  ${harness_name} (registered)"
        echo "    script:     ${script_path}"
        echo "    config_dir: ${config_dir_harness}"
        echo "    data_dir:   ${data_dir_harness}"
    done
}

# ─── Command: register ──────────────────────────────────────────────────────

cmd_register() {
    local harness_name="${1:-}"
    local script_path="${2:-}"
    local config_dir_override=""
    local data_dir_override=""

    if [[ -z "${harness_name}" ]] || [[ -z "${script_path}" ]]; then
        die "Usage: agent-sandbox register <name> <script-path> [--config-dir <dir>] [--data-dir <dir>]"
    fi

    # Parse optional flags
    shift 2 || true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --config-dir)
                config_dir_override="${2:-}"
                shift 2
                ;;
            --data-dir)
                data_dir_override="${2:-}"
                shift 2
                ;;
            *)
                die "Unknown option: $1"
                ;;
        esac
    done

    # Resolve script path to absolute
    script_path="$(cd "$(dirname "${script_path}")" && pwd)/$(basename "${script_path}")"

    if [[ ! -f "${script_path}" ]]; then
        die "Harness script not found: ${script_path}"
    fi

    # Validate the script defines required variables
    # shellcheck source=/dev/null
    source "${script_path}"
    if [[ -z "${HARNESS_NAME:-}" ]]; then
        die "Harness script must define HARNESS_NAME: ${script_path}"
    fi

    # Use script defaults if not provided
    if [[ -z "${config_dir_override}" ]]; then
        config_dir_override="${HARNESS_DEFAULT_CONFIG_DIR:-}"
    fi
    if [[ -z "${data_dir_override}" ]]; then
        data_dir_override="${HARNESS_DEFAULT_DATA_DIR:-}"
    fi

    local config_file
    config_file="$(get_config_file)"

    if [[ ! -f "${config_file}" ]]; then
        info "Config file not found. Running 'agent-sandbox init' first..."
        cmd_init
    fi

    # Update config.json with the new harness
    local tmp_file
    tmp_file="$(mktemp)"
    jq --arg name "${harness_name}" \
       --arg script "${script_path}" \
       --arg config_dir "${config_dir_override}" \
       --arg data_dir "${data_dir_override}" \
       '.harnesses[$name] = {"script": $script, "config_dir": $config_dir, "data_dir": $data_dir}' \
       "${config_file}" > "${tmp_file}" && mv "${tmp_file}" "${config_file}"

    info "Registered harness '${harness_name}' with script ${script_path}"
    info "Config directory: ${config_dir_override}"
    info "Data directory: ${data_dir_override}"
}

# ─── Command: unregister ─────────────────────────────────────────────────────

cmd_unregister() {
    local harness_name="${1:-}"

    if [[ -z "${harness_name}" ]]; then
        die "Usage: agent-sandbox unregister <name>"
    fi

    local config_file
    config_file="$(get_config_file)"

    if [[ ! -f "${config_file}" ]]; then
        die "Config file not found. Run 'agent-sandbox init' first."
    fi

    local tmp_file
    tmp_file="$(mktemp)"
    jq --arg name "${harness_name}" 'del(.harnesses[$name])' "${config_file}" > "${tmp_file}" && mv "${tmp_file}" "${config_file}"

    info "Unregistered harness '${harness_name}'"
}

# ─── Command: doctor ─────────────────────────────────────────────────────────

cmd_doctor() {
    local status=0
    local PASS="[PASS]"
    local WARN="[WARN]"
    local FAIL="[FAIL]"

    echo "agent-sandbox health check"
    echo "========================="
    echo ""

    # Docker binary
    if command -v docker > /dev/null 2>&1; then
        echo "  ${PASS} docker binary available"
    else
        echo "  ${FAIL} docker not found — install Docker: https://docs.docker.com/get-docker/"
        status=1
    fi

    # Docker daemon
    if docker info > /dev/null 2>&1; then
        echo "  ${PASS} docker daemon running"
    else
        echo "  ${FAIL} docker daemon not running — start Docker Desktop or dockerd"
        status=1
    fi

    # jq
    if command -v jq > /dev/null 2>&1; then
        echo "  ${PASS} jq available"
    else
        echo "  ${FAIL} jq not found — install jq: https://jqlang.github.io/jq/"
        status=1
    fi

    # Config file
    local config_dir config_file
    config_dir="$(get_config_file_dir)"
    config_file="${config_dir}/config.json"

    if [[ -f "${config_file}" ]]; then
        echo "  ${PASS} config file: ${config_file}"
        # Validate JSON
        if jq empty "${config_file}" > /dev/null 2>&1; then
            echo "  ${PASS} config file is valid JSON"
        else
            echo "  ${FAIL} config file is not valid JSON — run 'agent-sandbox init --force' to recreate"
            status=1
        fi
    else
        echo "  ${FAIL} config file not found — run 'agent-sandbox init'"
        status=1
        echo ""
        if [[ "${status}" -eq 0 ]]; then
            echo "All checks passed."
        else
            echo "One or more checks failed. See [FAIL] items above."
        fi
        exit "${status}"
    fi

    echo ""

    # Check each built-in harness
    local harness_dir harness_name
    for harness_dir in "${AGENT_SANDBOX_DIR}/harnesses"/*/; do
        harness_name="$(basename "${harness_dir}")"
        if [[ "${harness_name}" == "template" ]]; then
            continue
        fi

        echo "  Harness: ${harness_name}"

        local harness_script="${harness_dir}${harness_name}.sh"
        if [[ ! -f "${harness_script}" ]]; then
            echo "  ${FAIL} script not found: ${harness_script}"
            status=1
            continue
        fi

        echo "  ${PASS} script: ${harness_script}"

        # Image
        # shellcheck source=/dev/null
        source "${harness_script}"
        if docker image inspect "${HARNESS_IMAGE}" > /dev/null 2>&1; then
            echo "  ${PASS} image: ${HARNESS_IMAGE}"
        else
            echo "  ${WARN} image: ${HARNESS_IMAGE} not found — run 'agent-sandbox ${harness_name} build' or it will auto-build on first run"
        fi

        # Config directory
        local config_dir_val
        config_dir_val="$(get_config_dir "${harness_name}")"
        if [[ -d "${config_dir_val}" ]]; then
            echo "  ${PASS} config_dir: ${config_dir_val}"
        else
            echo "  ${WARN} config_dir: ${config_dir_val} does not exist — it will be created on first run"
        fi

        # Data directory
        local data_dir_val
        data_dir_val="$(get_data_dir "${harness_name}")"
        if [[ -d "${data_dir_val}" ]]; then
            echo "  ${PASS} data_dir: ${data_dir_val}"
        else
            echo "  ${WARN} data_dir: ${data_dir_val} does not exist — it will be created on first run"
        fi
    done

    echo ""
    if [[ "${status}" -eq 0 ]]; then
        echo "All checks passed."
    else
        echo "One or more checks failed. See [FAIL] items above."
    fi
    echo ""

    exit "${status}"
}

# ─── Command: build ──────────────────────────────────────────────────────────

cmd_build() {
    local harness_name="${1:-}"
    if [[ -z "${harness_name}" ]]; then
        die "Usage: agent-sandbox <harness> build"
    fi

    load_harness "${harness_name}"
    build_image
    info "Image '${HARNESS_IMAGE}' built successfully."
}

# ─── Command: test ───────────────────────────────────────────────────────────

cmd_test() {
    local harness_name="${1:-}"
    if [[ -z "${harness_name}" ]]; then
        die "Usage: agent-sandbox test <harness>"
    fi

    local test_script="${AGENT_SANDBOX_DIR}/lib/tests/container-security.sh"
    local run_wrapper="${AGENT_SANDBOX_DIR}/lib/tests/run-security-test.sh"
    if [[ ! -f "${test_script}" ]]; then
        die "Test script not found: ${test_script}"
    fi
    if [[ ! -f "${run_wrapper}" ]]; then
        die "Test wrapper not found: ${run_wrapper}"
    fi

    load_harness "${harness_name}"

    # Mount both scripts and override entrypoint to bash so output is immediate
    # (pi/opencode buffer output, which delays the "Running..." message)
    EXTRA_DOCKER_VOLUMES=(
        "--volume" "${test_script}:/usr/local/bin/container-security.sh:ro"
        "--volume" "${run_wrapper}:/usr/local/bin/run-security-test.sh:ro"
    )
    ENTRYPOINT_OVERRIDE="bash"
    run_container /usr/local/bin/run-security-test.sh
}

# ─── Command: upgrade ────────────────────────────────────────────────────────

cmd_upgrade() {
    local harness_name="${1:-}"
    if [[ -z "${harness_name}" ]]; then
        die "Usage: agent-sandbox <harness> upgrade"
    fi

    load_harness "${harness_name}"

    # Warn if a version is pinned in config — upgrading will reinstall the same version
    if [[ -f "${CONFIG_FILE}" ]]; then
        local pinned_version
        pinned_version="$(jq -r ".harnesses.\"${harness_name}\".version // \"\"" "${CONFIG_FILE}" 2>/dev/null)" || pinned_version=""
        if [[ -n "${pinned_version}" ]]; then
            echo ""
            echo -e "\033[1;33m⚠ Version is pinned to ${pinned_version} in config.json.\033[0m"
            echo -e "\033[1;33m  Remove the 'version' field to upgrade to latest.\033[0m"
            echo -e "\033[1;33m  Running 'agent-sandbox ${harness_name} upgrade' will reinstall version ${pinned_version}.\033[0m"
            echo ""
        fi
    fi

    info "Rebuilding '${HARNESS_IMAGE}'..."
    docker image rm "${HARNESS_IMAGE}" 2>/dev/null || true
    build_image --no-cache
    info "Image '${HARNESS_IMAGE}' rebuilt."
}

# ─── Main ────────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
agent-sandbox — Run AI coding harnesses inside Docker containers

Usage:
  agent-sandbox init                           Create config file
  agent-sandbox doctor                         Check setup for problems
  agent-sandbox list                           List registered harnesses
  agent-sandbox register <name> <path> [--config-dir <dir>] [--data-dir <dir>]
                                               Register a new harness
  agent-sandbox unregister <name>              Unregister a harness
  agent-sandbox test <harness>                Run security verification tests
  agent-sandbox <harness> [args...]            Run a harness
  agent-sandbox <harness> build                Build the harness Docker image
  agent-sandbox <harness> upgrade              Upgrade the harness (if supported)

Environment variables:
  AGENT_SANDBOX_CONFIG_DIR                     Override config directory for one run
  AGENT_SANDBOX_DATA_DIR                       Override data directory for one run
EOF
}

# Parse the first argument
if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

command="$1"
shift

case "${command}" in
    init)
        cmd_init "$@"
        ;;
    doctor)
        cmd_doctor
        ;;
    list)
        cmd_list
        ;;
    register)
        cmd_register "$@"
        ;;
    test)
        cmd_test "${1:-}"
        ;;
    unregister)
        cmd_unregister "$@"
        ;;
    -*)
        usage
        exit 1
        ;;
    *)
        # It's a harness name or harness+subcommand
        harness_name="${command}"

        # Check for build/upgrade subcommands
        sub_cmd="${1:-}"
        case "${sub_cmd}" in
            build)
                shift || true
                cmd_build "${harness_name}"
                ;;
            upgrade)
                shift || true
                cmd_upgrade "${harness_name}"
                ;;
            *)
                # Run the harness
                load_harness "${harness_name}"
                run_container "$@"
                ;;
        esac
        ;;
esac